<Window x:Class="CodexStatus.Tray.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex Status Settings"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen">
    <Border Padding="18" Background="#F8FAFC">
        <StackPanel>
            <TextBlock Text="Codex Status Settings" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" />
            <UniformGrid Columns="2" Margin="0,14,0,0">
                <CheckBox x:Name="ShowFloatingPillCheckBox" Content="Show floating pill" Margin="0,0,12,8" />
                <CheckBox x:Name="AlwaysOnTopCheckBox" Content="Always on top" Margin="0,0,0,8" />
                <CheckBox x:Name="PlaySoundOnDoneCheckBox" Content="Play sound on done" Margin="0,0,12,8" />
                <CheckBox x:Name="PlaySoundOnApprovalCheckBox" Content="Play sound on approval" Margin="0,0,0,8" />
                <CheckBox x:Name="HideCommandTextCheckBox" Content="Hide command text" Margin="0,0,12,8" />
                <CheckBox x:Name="RedactSecretsCheckBox" Content="Redact secrets" Margin="0,0,0,8" />
                <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start with Windows" Margin="0,0,12,8" />
            </UniformGrid>

            <TextBlock Text="Codex home path" FontWeight="SemiBold" Margin="0,12,0,4" />
            <TextBox x:Name="CodexHomePathTextBox" MinWidth="460" />
            <TextBlock Text="State directory" FontWeight="SemiBold" Margin="0,12,0,4" />
            <TextBox x:Name="StateDirectoryTextBox" MinWidth="460" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Open state folder" MinWidth="118" Margin="0,0,8,0" Click="OnOpenStateFolder" />
                <Button Content="Reinstall hooks" MinWidth="112" Margin="0,0,8,0" Click="OnReinstallHooks" />
                <Button Content="Save" MinWidth="82" Click="OnSave" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
